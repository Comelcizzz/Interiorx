{
	"name": "@tailored/backend",
	"version": "0.1.0",
	"private": true,
	"type": "commonjs",
	"scripts": {
		"dev": "nest start --watch",
		"build": "nest build",
		"start": "nest start",
		"start:prod": "node dist/apps/backend/src/main.js",
		"lint": "eslint \"{src,test}/**/*.{ts,js}\"",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.ts\"",
		"test": "jest --runInBand",
		"test:e2e": "jest --config test/jest-e2e.json --runInBand",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate deploy",
		"prisma:dev": "prisma migrate dev",
		"prisma:seed": "ts-node prisma/seed.ts",
		"seed": "ts-node -r tsconfig-paths/register scripts/seed-mongo.ts",
		"ensure:demo-assets": "ts-node -r tsconfig-paths/register scripts/ensure-demo-assets.ts",
		"start:render": "node scripts/render-start.mjs",
		"seed:report": "ts-node -r tsconfig-paths/register scripts/count-collections.ts",
		"prisma:reset": "prisma migrate reset --force"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.19",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.1.19",
		"@nestjs/jwt": "^11.0.1",
		"@nestjs/mongoose": "^11.0.4",
		"@nestjs/platform-express": "^11.1.19",
		"@nestjs/swagger": "^11.4.2",
		"@prisma/client": "^6.1.0",
		"bcrypt": "^6.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"date-fns": "^4.1.0",
		"dejavu-fonts-ttf": "^2.37.3",
		"express": "^5.2.1",
		"mongoose": "^9.6.1",
		"multer": "^2.1.1",
		"pdfkit": "^0.15.2",
		"qrcode": "^1.5.4",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"uuid": "^11.0.3"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.21",
		"@nestjs/schematics": "^11.1.0",
		"@nestjs/testing": "^11.1.19",
		"@types/bcrypt": "^5.0.2",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/multer": "^2.1.0",
		"@types/node": "^22.10.2",
		"@types/pdfkit": "^0.13.9",
		"@types/qrcode": "^1.5.6",
		"@types/supertest": "^6.0.2",
		"@typescript-eslint/eslint-plugin": "^8.18.1",
		"@typescript-eslint/parser": "^8.18.1",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"jest": "^29.7.0",
		"prisma": "^6.1.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.1",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.5.4"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"src/**/*.(t|j)s"
		],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node"
	}
}
