{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"compilerOptions": {
		"deleteOutDir": true
	},
	"monorepo": true,
	"root": ".",
	"projects": {
		"tailored-api": {
			"type": "application",
			"root": ".",
			"entryFile": "main",
			"sourceRoot": "src",
			"compilerOptions": {
				"tsConfigPath": "tsconfig.json"
			}
		},
		"common": {
			"type": "library",
			"root": "libs/common",
			"entryFile": "index",
			"sourceRoot": "libs/common/src",
			"compilerOptions": {
				"tsConfigPath": "libs/common/tsconfig.lib.json"
			}
		}
	}
}
