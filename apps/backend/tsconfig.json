{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "commonjs",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"target": "ES2022",
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"incremental": true,
		"noEmit": false,
		"strictPropertyInitialization": false,
		"paths": {
			"@tailored/shared": ["../../packages/shared/src"]
		}
	},
	"include": ["src/**/*.ts", "scripts/**/*.ts", "prisma/**/*.ts", "test/**/*.ts"]
}
